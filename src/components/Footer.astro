---
/*
  Shared site footer — brand + affiliate disclosure + social buttons.
  Static-HTML successor to renderFooter() from the old js/site.js;
  markup + classes kept identical so css/styles.css styles it as before.

  To add more social buttons later, copy the <a class="social-btn"> block.
*/
const brand = 'My Sewing Picks';
const disclosure = 'As an Amazon Associate I earn from qualifying purchases.';
const youtubeUrl = 'https://www.youtube.com/channel/UCbsWzrIcuaQQSdWRqh3FTmg';
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <span class="site-footer__name">{brand}</span>
      <p class="affiliate-disclosure">{disclosure}</p>
    </div>

    <!-- Social buttons corner. Add more here later. -->
    <div class="socials" aria-label="Social links">
      <a class="social-btn" href={youtubeUrl} target="_blank" rel="noopener"
         aria-label="YouTube" title="YouTube">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.3 3.6-6.3 3.6Z"/></svg>
      </a>
    </div>
  </div>
</footer>
