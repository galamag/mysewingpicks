---
/*
  Shared site header — logo + primary nav + mobile hamburger.
  Reused on every page. Pass `active` (e.g. "about") to highlight the
  current page's nav link.

  This is the static-HTML successor to renderHeader() from the old
  js/site.js. Markup + classes are kept identical so css/styles.css styles
  it exactly as before.
*/
const { active } = Astro.props;

const brand = 'My Sewing Picks';
const nav = [
  { key: 'home', label: 'Home', href: 'index.html' },
  { key: 'tools', label: 'Tools', href: 'tools.html' },
  { key: 'fabrics', label: 'Fabrics', href: 'fabrics.html' },
  { key: 'about', label: 'About', href: 'about.html' },
];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="index.html" aria-label={`${brand} — home`}>
      <!-- Logo image. If /assets/logo.png is missing, onerror swaps in a text wordmark. -->
      <img
        class="brand__logo"
        src="/assets/logo.png"
        alt={`${brand} logo`}
        onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
      />
      <span class="brand__wordmark" style="display:none;">{brand}</span>
    </a>

    <!-- Hamburger toggle (shown on small screens via CSS) -->
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} aria-current={active === item.key ? 'page' : undefined}>{item.label}</a>
      ))}
      {/*
        FUTURE: language switcher placeholder goes here (the site is
        English-only for now — intentionally omitted).
      */}
    </nav>
  </div>
</header>

<script>
  // Mobile menu open/close (mirrors the old js/site.js hamburger behavior).
  const header = document.querySelector('.site-header');
  const toggle = header?.querySelector('.nav-toggle');
  const nav = header?.querySelector('.site-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
