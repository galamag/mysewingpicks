# Supply-chain hardening (intentional).
# Never run package lifecycle scripts (preinstall/install/postinstall/prepare)
# automatically on install. Defends against malicious scripts that exfiltrate
# SSH keys / tokens (Shai-Hulud / Miasma npm wave).
# If a package legitimately needs a build step, run it DELIBERATELY after vetting.
ignore-scripts=true
fund=false
